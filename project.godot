; Engine configuration file.
; It's best edited using the editor UI and not directly.

config_version=5

[application]
config/name="قبضة الجنرال"
config/description="لعبة استراتيجية Idle عسكرية - غرفة العمليات والمعارك التكتيكية"
config/version="2.1.0"
config/icon="res://icon.png"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0.02, 0.03, 0.06, 1)
boot_splash/image="res://assets/splash.png"
boot_splash/fullsize=false
boot_splash/use_filter=true

[autoload]
game_manager="*res://autoload/game_manager.gd"

[display]
window/size/viewport_width=420
window/size/viewport_height=780
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1
window/ios/allow_high_refresh_rate=true
window/vsync/vsync_mode=0
window/anti_aliasing/quality/msaa_3d=2

[input_devices]
pointing/emulate_touch_from_mouse=true

[rendering]
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
quality/fill_mode=2
